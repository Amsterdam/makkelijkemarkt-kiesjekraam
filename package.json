{
  "name": "@fixxx/pakjekraam",
  "version": "0.0.1",
  "description": "",
  "repository": "https://git.data.amsterdam.nl:salmagundi/makkelijkemarkt/makkelijkemarkt-kiesjekraam.git",
  "main": "src/index.ts",
  "directories": {},
  "scripts": {
    "build": "sass --style=compressed src/scss/screen.scss dist/style/screen.css",
    "build:typescript": "tsc --project tsconfig.json",
    "clean": "rm -rf dist/* node_modules/.cache/",
    "dev-server": "npm run dev",
    "start": "ts-node --transpile-only src/index.ts",
    "dev": "ENABLE_CORS_FOR_ORIGIN='http://localhost:3000' ts-node-dev --transpile-only --ignore-watch node_modules src/index.ts",
    "allocation": "ts-node src/allocation.ts",
    "lint": "npm run lint:eslint",
    "lint:eslint": "eslint './src/**/*.js' './src/**/*.jsx' './src/**/*.ts' './src/**/*.tsx'",
    "lint-fix": "npm run lint-fix:eslint; npm run lint-fix:prettier",
    "lint-fix:eslint": "npm run lint:eslint -- --fix",
    "lint-fix:prettier": "prettier --write '**/*.js' '**/*.json' '**/*.jsx' '*.yml'",
    "lint-non-npm": "git ls-files '*.yml' | tr '\n' '\\0' | xargs -0 yamllint",
    "prewatch": "npm run clean && npm run build",
    "sass": "sass --watch --style=compressed src/scss:dist/style"
  },
  "author": "",
  "license": "MPL-2.0",
  "devDependencies": {
    "@types/connect-pg-simple": "4.2.0",
    "@types/cookie-parser": "1.4.2",
    "@types/cors": "2.8.12",
    "@types/csurf": "1.9.36",
    "@types/express": "4.16.0",
    "@types/express-session": "1.15.10",
    "@types/keycloak-connect": "^7.0.0",
    "@types/lodash": "^4.17.24",
    "@types/morgan": "1.7.35",
    "@types/node": "24.1.0",
    "@types/node-sass": "4.11.2",
    "@types/prop-types": "15.7.1",
    "@types/qs": "6.5.3",
    "@types/react": "16.8.19",
    "@types/react-dom": "16.8.4",
    "@types/validator": "13.7.0",
    "@typescript-eslint/eslint-plugin": "5.13.0",
    "@typescript-eslint/parser": "5.13.0",
    "eslint": "8.10.0",
    "eslint-config-prettier": "4.3.0",
    "eslint-plugin-react": "^7.13.0",
    "husky": "2.3.0",
    "lint-staged": "12.3.4",
    "node-dev": "7.1.0",
    "prettier": "3.6.2",
    "webpack-cli": "^4.9.2"
  },
  "dependencies": {
    "@keycloak/keycloak-admin-client": "^26.5.4",
    "axios": "^1.6.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "csurf": "1.10.0",
    "dotenv": "8.1.0",
    "express": "4.22.1",
    "express-react-views": "^0.11.0",
    "express-session": "^1.17.2",
    "jsonschema": "1.2.5",
    "keycloak-connect": "21.1.1",
    "lodash": "^4.17.23",
    "moment": "2.29.4",
    "moment-timezone": "^0.5.43",
    "morgan": "1.10.1",
    "prop-types": "15.7.2",
    "qs": "6.15.0",
    "react": "16.8.6",
    "react-dom": "16.8.6",
    "react-qr-svg": "2.2.1",
    "sass": "1.49.9",
    "sortablejs": "1.10.1",
    "ts-node": "^10.0.0",
    "ts-node-dev": "1.1.8",
    "typescript": "3.9.10",
    "webpack": "^5.76.0"
  },
  "overrides": {
    "json5": "^2.2.2",
    "glob-parent": "^5.1.2",
    "form-data": "^4.0.4",
    "cookie": "^0.7.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{js,json,jsx}": [
      "eslint"
    ],
    "src/**/*.{ts,tsx}": []
  }
}
